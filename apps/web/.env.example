# App
NEXT_PUBLIC_APP_URL=http://localhost:3000  # Production: https://your-domain.vercel.app

# NextAuth
AUTH_SECRET=                        # Generate with: openssl rand -base64 32

# Google OAuth (https://console.cloud.google.com)
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# Database (Supabase / Neon / any PostgreSQL)
DATABASE_URL=postgresql://user:password@host:6543/postgres?pgbouncer=true
DIRECT_URL=postgresql://user:password@host:5432/postgres

# Internal solver secret — must match INTERNAL_API_SECRET in services/solver
INTERNAL_API_SECRET=                # Generate with: openssl rand -hex 32
SOLVER_API_URL=http://localhost:8000
